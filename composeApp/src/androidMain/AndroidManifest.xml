<?xml version="1.0" encoding="utf-8"?>
<!--
    Library manifest for :composeApp (KMP module).

    ONLY declares components that are defined in this library.
    Permissions, the Application class, and the Activity all live in the
    :androidApp launcher module — they are merged into the final APK manifest
    by the Android Gradle Plugin at build time.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>

        <!--
            LocationForegroundService is implemented in androidMain of this
            library so it must be declared here. :androidApp's manifest will
            merge this declaration automatically.
        -->
        <service
            android:name="com.tcontur.central.core.location.background.LocationForegroundService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!--
            WebSocket foreground service – maintains the protobin WS connection in background.
            foregroundServiceType="dataSync" is required for Android 14+ (API 34+).
        -->
        <service
            android:name="com.tcontur.central.core.services.SocketService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>